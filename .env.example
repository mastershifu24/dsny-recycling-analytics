# Copy this file to ".env" in the same folder (repo root) and fill in values.
# ".env" is gitignored—never commit real keys.
#
#   copy .env.example .env
#
# Gemini (text + multimodal photo): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: Google Maps Platform — live traffic for /api/route/optimize (billing; enable Routes API + Distance Matrix + Directions)
# GOOGLE_MAPS_API_KEY=

# Optional: higher SODA rate limits
# SOCRATA_APP_TOKEN=

# Optional: SODA column id for garbage tons (default matches NYC DSNY monthly tonnage dataset)
# NYC_SODA_GARBAGE_TONS_FIELD=
